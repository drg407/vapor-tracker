{
    "manifest_version": 3,
    "name": "Vapor Tracker",
    "version": "0.1",
    "description": "Shows historical low and current best price from other stores on Steam pages (IsThereAnyDeal data).",
    "icons": {
        "16": "img/icon16.png",
        "32": "img/icon32.png",
        "48": "img/icon48.png",
        "64": "img/icon64.png",
        "96": "img/icon96.png",
        "128": "img/icon128.png",
        "256": "img/icon256.png",
        "512": "img/icon512.png"
    },
    "background": {
        "scripts": ["background.js"]
    },
    "permissions": ["storage"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "img/icon16.png",
            "32": "img/icon32.png",
            "48": "img/icon48.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://store.steampowered.com/*",
                "*://steamcommunity.com/*"
            ],
            "js": ["banner.js"],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://store.steampowered.com/app/*",
                "*://store.steampowered.com/sub/*",
                "*://store.steampowered.com/bundle/*"
            ],
            "js": ["content.js"],
            "css": ["content.css"],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://store.steampowered.com/wishlist/*"
            ],
            "js": ["wishlist.js"],
            "css": ["content.css"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "https://api.isthereanydeal.com/*"
    ]
}
